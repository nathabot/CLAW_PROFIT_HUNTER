{
  "name": "twitter-trading-scraper",
  "version": "1.0.0",
  "description": "Twitter/X trading signal scraper and analyzer for crypto trading",
  "main": "agents/twitter-scraper.js",
  "scripts": {
    "init": "node scripts/init-db.js",
    "scrape": "node agents/twitter-scraper.js",
    "scrape:account": "node agents/twitter-scraper.js --account",
    "analyze": "node agents/twitter-analyzer.js --report",
    "analyze:token": "node agents/twitter-analyzer.js --token",
    "mock": "node test/generate-mock-data.js",
    "test": "node test/test-scraper.js",
    "cron:scrape": "node agents/twitter-scraper.js >> logs/scraper.log 2>&1",
    "cron:analyze": "node agents/twitter-analyzer.js --report >> logs/analyzer.log 2>&1"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "axios": "^1.13.5",
    "bs58": "^6.0.0",
    "node-fetch": "^2.7.0",
    "sqlite3": "^5.1.7",
    "xml2js": "^0.6.2"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "twitter",
    "trading",
    "crypto",
    "signals",
    "scraper",
    "sentiment-analysis"
  ],
  "author": "Trading Bot",
  "license": "MIT"
}
