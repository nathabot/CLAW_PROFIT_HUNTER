{
  "apps": [
    {
      "name": "trading-dashboard",
      "script": "./src/dashboard-server.js",
      "cwd": "/root/trading-bot",
      "env": {
        "DASHBOARD_PORT": "8080"
      },
      "log_file": "./logs/dashboard.log",
      "out_file": "./logs/dashboard-out.log",
      "error_file": "./logs/dashboard-error.log",
      "merge_logs": true,
      "time": true,
      "autorestart": true,
      "max_restarts": 5,
      "min_uptime": "10s",
      "restart_delay": 3000
    }
  ]
}
